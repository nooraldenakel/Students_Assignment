  {
    "id": "TC001",
    "title": "Login with valid credentials redirects to dashboard",
    "description": "Verifies an admin can sign in from the login page and is redirected to the main dashboard.",
    "category": "Authentication",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/login\""
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign In\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/\""
      },
      {
        "type": "assertion",
        "description": "Verify page title contains \"Dashboard\""
      }
    ]
  },
  {
